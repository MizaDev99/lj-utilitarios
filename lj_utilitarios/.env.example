# Django
SECRET_KEY=django-insecure-troque-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (PostgreSQL via Supabase)
# Se não definido, usa SQLite para desenvolvimento
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=sua-senha-supabase
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432

# Supabase Storage
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=seu-anon-key
SUPABASE_SERVICE_KEY=seu-service-key

# Firebase (backend - Admin SDK)
# Caminho para o arquivo JSON da service account baixado do Firebase Console
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json

