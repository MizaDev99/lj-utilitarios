# Django
SECRET_KEY=django-insecure-troque-por-valor-unico-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (PostgreSQL via Supabase)
# Se não definido, usa SQLite automaticamente para desenvolvimento
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_HOST=db.SEU-ID-SUPABASE.supabase.co
DB_PORT=5432

# Supabase Storage (opcional — usa armazenamento local se não definido)
SUPABASE_URL=https://SEU-ID-SUPABASE.supabase.co
SUPABASE_ANON_KEY=seu-anon-key-aqui
SUPABASE_SERVICE_KEY=seu-service-key-aqui

# Firebase Web SDK (frontend — valores do Console Firebase > Configurações do projeto)
FIREBASE_API_KEY=seu-api-key-aqui
FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Admin SDK (backend — caminho para o JSON baixado do Firebase Console)
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json
